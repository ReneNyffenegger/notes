$clip = [Windows.Clipboard]::GetDataObject()

foreach ($fmt in $clip.GetFormats()) {
   try {
      $dat = $clip.GetData($fmt)
      $typ = $dat.GetType()
   }
   catch {
      $typ = '?'
   }

   '{0,-50} {1}' -f $fmt, $typ
}
